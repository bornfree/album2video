ALBUM_ROOT=/path/to/albums

# TV / Output spec
OUTPUT_WIDTH=3840
OUTPUT_HEIGHT=2160
OUTPUT_FPS=30
VIDEO_BITRATE=20M
H264_PROFILE=high
H264_LEVEL=5.1
AUDIO_BITRATE=192k

# Media sorting: "date", "name", or "random"
SORT_ORDER=date

# Ken Burns (set to false to disable zoom/pan effect)
KEN_BURNS=true
PHOTO_DURATION=10
AUDIO_CROSSFADE=3
